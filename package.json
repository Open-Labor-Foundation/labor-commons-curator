{
  "name": "autonomous-3-build-time-schema-pull-generated-types",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc && node -r esbuild-register src/schemas/generated-types.config.ts",
    "generate:types": "json2ts --input src/schema.json --output src/types/ && json2ts --input src/schemas/example.schema.json --output src/types/",
    "validate:schema": "z-schema src/schema.json src/schemas/"
  },
  "dependencies": {
    "@types/json-schema": "^7.0.15",
    "json-schema-to-typescript": "^4.6.5",
    "json-schema-ref-parser": "^3.3.1",
    "z-schema": "^3.25.1"
  }
}